# Generated by Fablo-FabricX
# This file bootstraps a complete Fabric-X token network.
# Do not edit manually — regenerate with: npm run generate

networks:
  test:
    name: fabric_test
    external: true

services:

<% orgs.forEach(function(org) { -%>
<% if (org.committers) { -%>
<% org.committers.forEach(function(committer) { -%>
  <%= committer.name %>:
    image: <%= global.fabricXImages.committerTestNode %>
    container_name: test-committer
    restart: unless-stopped
    environment:
      - SC_SIDECAR_ORDERER_IDENTITY_MSP_DIR=/root/config/crypto/peerOrganizations/<%= org.organization.domain %>/peers/SC.<%= org.organization.domain %>/msp
      - SC_SIDECAR_ORDERER_IDENTITY_MSP_ID=<%= committer.sidecar.mspId %>
      - SC_SIDECAR_ORDERER_CHANNEL_ID=<%= committer.sidecar.channelId %>
      - SC_SIDECAR_ORDERER_SIGNED_ENVELOPES=<%= committer.sidecar.signedEnvelopes %>
      - SC_QUERY_SERVICE_SERVER_ENDPOINT=:<%= committer.ports.queryService %>
      - SC_ORDERER_BLOCK_SIZE=<%= committer.sidecar.blockSize %>
      - SC_SIDECAR_LOGGING_LEVEL=<%= committer.logging.sidecar %>
      - SC_QUERY_SERVICE_LOGGING_LEVEL=<%= committer.logging.queryService %>
      - SC_COORDINATOR_LOGGING_LEVEL=<%= committer.logging.coordinator %>
      - SC_ORDERER_LOGGING_LEVEL=<%= committer.logging.orderer %>
      - SC_VC_LOGGING_LEVEL=<%= committer.logging.vc %>
      - SC_VERIFIER_LOGGING_LEVEL=<%= committer.logging.verifier %>
    ports:
      - "<%= committer.ports.sidecar %>:4001"
      - "<%= committer.ports.queryService %>:7001"
      - "<%= committer.ports.orderer %>:7050"
      - "<%= committer.ports.database %>:5433"
    expose:
      - "4001"
      - "7001"
      - "7050"
      - "5433"
    volumes:
      - ./crypto:/root/config/crypto
      - ./crypto/sc-genesis-block.proto.bin:/root/config/sc-genesis-block.proto.bin
    command: run db orderer committer
    healthcheck:
      test: ["CMD", "nc", "-z", "127.0.0.1", "4001"]
      interval: 5s
      timeout: 1s
      retries: 5
      start_period: 10s
    networks:
      - test
<% }); -%>
<% } -%>
<% }); -%>

<% allFscNodes.forEach(function(fscNode) { -%>
<% if (fscNode.role !== 'auditor') { -%>
  <%= fscNode.name %>:
    hostname: <%= fscNode.name %>.example.com
    build:
      context: .
      dockerfile: Dockerfile
      args:
        NODE_TYPE: <%= fscNode.role === 'owner' ? 'owner' : (fscNode.role === 'issuer' ? 'issuer' : 'endorser') %>
        PLATFORM: "fabricx"
    restart: unless-stopped
    extra_hosts:
      - "committer-sidecar:host-gateway"
      - "committer-queryservice:host-gateway"
      - "orderer.example.com:host-gateway"
    expose:
      - "9001"
      - "<%= fscNode.ports.p2p %>"
    ports:
      - "<%= fscNode.ports.api %>:9000/tcp"
    volumes:
      - ./${CONF_ROOT:-conf}/<%= fscNode.name %>:/conf
<% if (fscNode.role === 'endorser') { -%>
      - ./${CONF_ROOT:-conf}/namespace/zkatdlognoghv1_pp.json:/namespace/zkatdlognoghv1_pp.json
<% } -%>
    depends_on:
<% orgs.forEach(function(org) { -%>
<% if (org.committers && org.committers.length > 0) { -%>
      <%= org.committers[0].name %>:
        condition: service_healthy
<% } -%>
<% }); -%>
    healthcheck:
      test: ["CMD", "nc", "-z", "127.0.0.1", "9000"]
      interval: 5s
      timeout: 1s
      retries: 5
      start_period: 10s
    networks:
      - test

<% } -%>
<% }); -%>
  swagger-ui:
    image: swaggerapi/swagger-ui
    restart: unless-stopped
    ports:
      - "8080:8080"
    environment:
      - URL=/swagger.yaml
    volumes:
      - ./swagger.yaml:/usr/share/nginx/html/swagger.yaml
    networks:
      - test
