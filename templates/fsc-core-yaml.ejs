# FSC core.yaml for <%= node.name %>
# Generated by Fablo-X config generator

logging:
  spec: info
  format: "%{color}%{time:15:04:05.000} [%{module}] %{shortfunc} %{level:.4s}%{color:reset} %{message}"

fsc:
  id: <%= node.fsc.id %> # CORE_FSC_ID
  identity:
    cert:
      file: ./keys/node.crt
    key:
      file: ./keys/node.key
  p2p:
    listenAddress: <%= node.fsc.p2pListenAddress %> # CORE_P2P_LISTENADDRESS
    type: websocket
    opts:
      routing:
        path: ./routing-config.yaml
  persistences:
    default:
      type: sqlite
      opts:
        dataSource: <%= node.db.datasource %> # CORE_FSC_PERSISTENCES_OPTS_DATASOURCE
  endpoint:
    resolvers:
<% allFscNodes.forEach(function(peer) { -%>
<% if (!peer.excludeFromResolvers) { -%>
      - name: <%= peer.name %>
        identity:
          id: <%= peer.name %>
          path: ./keys/nodes/<%= peer.name %>.crt
        addresses:
          P2P: <%= peer.name %>.example.com:<%= peer.ports.p2p %>
<% } -%>
<% }); -%>

fabric:
  enabled: true
  default:
    driver: <%= node.fsc.driver %>
<% if (node.defaultMSP) { -%>
    defaultMSP: <%= node.defaultMSP %>
<% } -%>
    msps:
      - id: <%= node.fabricMspId %>
        mspType: bccsp
        mspID: <%= node.org.mspName %>
        path: ./keys/fabric/<%= node.fabricMspId %>
    tls:
      enabled: false
    peers:
      - address: committer-sidecar:<%= committer.ports.sidecar %>
        usage:<%- node.peerUsage ? ' ' + node.peerUsage : '' %>
    queryService:
      - address: committer-queryservice:<%= committer.ports.queryService %>
    channels:
      - name: <%= channelName %>
        default: true

<% if (node.role !== 'auditor') { -%>
token:
  enabled: true
  tms:
    mytms:
      network: default
      channel: <%= channelName %>
      namespace: token_namespace
      driver: zkatdlog
<% if (node.wallets) { -%>
      wallets:
<% if (node.wallets.issuers) { -%>
        issuers:
<% node.wallets.issuers.forEach(function(w) { -%>
          - id: <%= w.id %>
            path: <%= w.path %>
<% }); -%>
<% } -%>
<% if (node.wallets.owners) { -%>
        owners:
<% node.wallets.owners.forEach(function(w) { -%>
          - id: <%= w.id %>
            path: <%= w.path %>
<% }); -%>
<% } -%>
<% } -%>
      services:
        network:
          fabric:
            fsc_endorsement:
              endorser: <%= node.isEndorser %>
              id: endorser
              policy:
                type: all
              endorsers:
                - endorser1
                # - endorser2
<% if (node.hasPublicParameters) { -%>
      publicParameters:
        path: ../namespace/zkatdlognoghv1_pp.json
<% } -%>
<% } -%>
