# FSC core.yaml for <%= node.name %>
# Source: fabric-x/samples/tokens/conf/<%= node.name %>/core.yaml

logging:
  spec: info
  format: '%{color}%{time:2006-01-02 15:04:05.000 MST} [%{module}] %{shortfunc} -> %{level:.4s} %{id:03x}%{color:reset} %{message}'

fsc:
  id: <%= node.fsc.id %> # CORE_FSC_ID
  networkConfigPath: ""
  p2p:
    listenAddress: <%= node.fsc.p2pListenAddress %> # CORE_P2P_LISTENADDRESS
    type: libp2p
    opts:
      routing:
        path: /conf/routing-config.yaml
  identity:
    cert:
      file: /conf/fsc/<%= node.name %>/signcerts/<%= node.name %>-cert.pem
    key:
      file: /conf/fsc/<%= node.name %>/keystore/priv_sk
  persistences:
    default:
      type: sqlite
      opts:
        dataSource: <%= node.db.datasource %> # CORE_FSC_PERSISTENCES_OPTS_DATASOURCE
        skipPragmas: false
        maxOpenConns: 10
  endpoint:
    resolvers:
<% allFscNodes.forEach(function(peer) { -%>
<% if (!peer.excludeFromResolvers) { -%>
      - name: <%= peer.name %>
        domain: <%= peer.domain %>
        identity:
          id: <%= peer.name %>
          path: /conf/fsc/<%= peer.name %>/signcerts/<%= peer.name %>-cert.pem
        addresses:
          Listen: <%= peer.name %>.example.com:<%= peer.ports.p2p %>
<% } -%>
<% }); -%>

fabric:
  enabled: true
  default:
    driver: <%= node.fsc.driver %>
    msps:
      - id: endorser
        mspType: bccsp
        mspID: <%= node.org.mspName %>
        path: /conf/fabric/<%= node.name %>
    tls:
      enabled: false
    peers:
      - address: committer-sidecar:<%= committer.ports.sidecar %>
        usage:<%- node.peerUsage ? ' ' + node.peerUsage : '' %>
    queryService:
      - address: committer-queryservice:<%= committer.ports.queryService %>
    channels:
      - name: <%= channelName %>
        default: true

<% if (node.role !== 'auditor') { -%>
token:
  enabled: true
  tms:
    mytms:
      network: default
      channel: <%= channelName %>
      namespace: token_namespace
      driver: zkatdlog
      services:
        network:
          fabric:
            fsc_endorsement:
              endorser: true
              id: endorser
              policy:
                type: all
              endorsers:
                - endorser1
      publicParameters:
        path: ../namespace/zkatdlognoghv1_pp.json
<% } -%>
