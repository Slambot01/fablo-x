{
  "global": {
    "fabricVersion": "x-0.1.7",
    "caVersion": "1.5.12",
    "engine": "fabric-x",
    "tls": true,
    "fabricXImages": {
      "committerTestNode": "ghcr.io/hyperledger/fabric-x-committer-test-node:0.1.7",
      "toolsBaseImage": "registry.access.redhat.com/ubi9/ubi-minimal:9.6"
    }
  },
  "orgs": [
    {
      "organization": {
        "name": "Org1",
        "domain": "org1.example.com",
        "mspName": "Org1MSP"
      },
      "ca": {
        "prefix": "ca",
        "db": "sqlite",
        "port": 7054
      },
      "committers": [
        {
          "name": "committer-test-node",
          "mode": "bundled",
          "ports": {
            "sidecar": 4001,
            "orderer": 7050,
            "queryService": 7001,
            "database": 5433
          },
          "sidecar": {
            "channelId": "mychannel",
            "blockSize": 1,
            "signedEnvelopes": true,
            "mspId": "Org1MSP"
          },
          "logging": {
            "sidecar": "DEBUG",
            "queryService": "DEBUG",
            "coordinator": "DEBUG",
            "orderer": "DEBUG",
            "vc": "DEBUG",
            "verifier": "INFO"
          }
        }
      ],
      "endorsers": [
        {
          "name": "endorser1",
          "nodeType": "endorser",
          "fsc": {
            "id": "endorser1",
            "driver": "fabricx"
          },
          "db": {
            "type": "sqlite",
            "datasource": "file:./data/fts.sqlite"
          },
          "role": "endorser"
        }
      ],
      "fscNodes": [
        {
          "name": "issuer",
          "domain": "org1.example.com",
          "role": "issuer",
          "wallets": {
            "issuers": [
              { "id": "iss", "path": "./keys/wallet/iss" }
            ]
          }
        },
        {
          "name": "auditor",
          "domain": "auditor.example.com",
          "role": "auditor"
        },
        {
          "name": "owner1",
          "domain": "org1.example.com",
          "role": "owner",
          "wallets": {
            "owners": [
              { "id": "alice", "path": "./keys/wallet/alice/msp" },
              { "id": "bob", "path": "./keys/wallet/bob/msp" }
            ]
          }
        },
        {
          "name": "owner2",
          "domain": "org1.example.com",
          "role": "owner",
          "defaultMSP": "user",
          "wallets": {
            "owners": [
              { "id": "carlos", "path": "./keys/wallet/carlos/msp" },
              { "id": "dan", "path": "./keys/wallet/dan/msp" }
            ]
          }
        }
      ]
    },
    {
      "organization": {
        "name": "Org2",
        "domain": "org2.example.com",
        "mspName": "Org2MSP"
      },
      "endorsers": [
        {
          "name": "endorser2",
          "nodeType": "endorser",
          "fsc": {
            "id": "endorser2",
            "driver": "fabricx"
          },
          "db": {
            "type": "sqlite",
            "datasource": "file:./data/fts.sqlite"
          },
          "peerUsage": "delivery",
          "role": "endorser"
        }
      ]
    }
  ],
  "channels": [
    {
      "name": "mychannel",
      "orgs": [
        {
          "name": "Org1",
          "endorsers": [
            "endorser1"
          ]
        },
        {
          "name": "Org2",
          "endorsers": [
            "endorser2"
          ]
        }
      ]
    }
  ]
}