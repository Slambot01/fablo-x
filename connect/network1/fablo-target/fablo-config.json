{
  "$schema": "https://github.com/hyperledger-labs/fablo/releases/download/2.6.0/schema.json",
  "global": {
    "fabricVersion": "2.5.9",
    "tls": true
  },
  "orgs": [
    {
      "organization": {
        "name": "Org1",
        "domain": "org1.example.com",
        "mspName": "Org1MSP"
      },
      "orderers": [
        {
          "groupName": "group1",
          "type": "raft",
          "instances": 1
        }
      ],
      "peer": {
        "instances": 1,
        "isEndorsingPeer": true
      },
      "ca": {
        "db": "sqlite"
      }
    }
  ],
  "channels": [
    {
      "name": "my-channel1",
      "orgs": [
        {
          "name": "Org1",
          "peers": ["peer0"]
        }
      ]
    }
  ],
  "chaincodes": []
}
