# Generated by Fablo (Fabric-X mode)
# Source reference: fabric-x/samples/tokens/compose.yml
#
# Design note: In real Fabric-X, the committer-test-node is external
# infrastructure and FSC nodes join the fabric_test network. Fablo bundles
# everything into one compose for single-command deployment.
# SC_SIDECAR_* env vars derived from fabric-x-committer image interface.

networks:
  test:
    name: fabric_test

services:

<% orgs.forEach(function(org) { -%>
<% if (org.ca) { -%>
  ca.<%= org.organization.domain %>:
    image: hyperledger/fabric-ca:<%= global.caVersion %>
    container_name: ca.<%= org.organization.domain %>
    restart: unless-stopped
    environment:
      - FABRIC_CA_HOME=/etc/hyperledger/fabric-ca-server
      - FABRIC_CA_SERVER_CA_NAME=ca.<%= org.organization.domain %>
      - FABRIC_CA_SERVER_TLS_ENABLED=<%= global.tls %>
    ports:
      - "<%= org.ca.port %>:7054"
    networks:
      - test
<% } -%>

<% if (org.committers) { -%>
<% org.committers.forEach(function(committer) { -%>
  <%= committer.name %>:
    image: <%= global.fabricXImages.committerTestNode %>
    container_name: <%= committer.name %>
    restart: unless-stopped
    environment:
      - SC_SIDECAR_ORDERER_IDENTITY_MSP_DIR=/root/config/crypto/peerOrganizations/<%= org.organization.domain %>/peers/SC.<%= org.organization.domain %>/msp
      - SC_SIDECAR_ORDERER_IDENTITY_MSP_ID=<%= committer.sidecar.mspId %>
      - SC_SIDECAR_ORDERER_CHANNEL_ID=<%= committer.sidecar.channelId %>
      - SC_SIDECAR_ORDERER_SIGNED_ENVELOPES=<%= committer.sidecar.signedEnvelopes %>
      - SC_QUERY_SERVICE_SERVER_ENDPOINT=:<%= committer.ports.queryService %>
      - SC_ORDERER_BLOCK_SIZE=<%= committer.sidecar.blockSize %>
      - SC_SIDECAR_LOGGING_LEVEL=<%= committer.logging.sidecar %>
      - SC_QUERY_SERVICE_LOGGING_LEVEL=<%= committer.logging.queryService %>
      - SC_COORDINATOR_LOGGING_LEVEL=<%= committer.logging.coordinator %>
      - SC_ORDERER_LOGGING_LEVEL=<%= committer.logging.orderer %>
      - SC_VC_LOGGING_LEVEL=<%= committer.logging.vc %>
      - SC_VERIFIER_LOGGING_LEVEL=<%= committer.logging.verifier %>
    ports:
      - "<%= committer.ports.sidecar %>:4001"
      - "<%= committer.ports.queryService %>:7001"
      - "<%= committer.ports.orderer %>:7050"
      - "<%= committer.ports.database %>:5433"
    volumes:
      - ./crypto:/root/config/crypto
      - ./crypto/sc-genesis-block.proto.bin:/root/config/sc-genesis-block.proto.bin
    healthcheck:
      test: ["CMD", "nc", "-z", "127.0.0.1", "4001"]
      interval: 5s
      timeout: 1s
      retries: 5
      start_period: 10s
    networks:
      - test
<% }); -%>
<% } -%>

<% if (org.endorsers) { -%>
<% org.endorsers.forEach(function(endorser) { -%>
  <%= endorser.name %>.<%= org.organization.domain %>:
    hostname: <%= endorser.name %>.example.com
    restart: unless-stopped
    build:
      context: .
      dockerfile: Dockerfile
      args:
        NODE_TYPE: <%= endorser.nodeType %>
        PLATFORM: "${PLATFORM:-fabricx}"
    container_name: <%= endorser.name %>.<%= org.organization.domain %>
    extra_hosts:
      - "committer-sidecar:host-gateway"
      - "committer-queryservice:host-gateway"
      - "orderer.example.com:host-gateway"
    expose:
      - 9001
      - <%= endorser.ports.p2p %>
    ports:
      - "<%= endorser.ports.api %>:9000/tcp"
    volumes:
      - ./${CONF_ROOT:-conf}/<%= endorser.name %>:/conf
<% if (endorser.name === 'endorser1') { -%>
      - ./${CONF_ROOT:-conf}/namespace/zkatdlognoghv1_pp.json:/namespace/zkatdlognoghv1_pp.json
<% } -%>
    depends_on:
<% var committerName = org.committers ? org.committers[0].name : orgs[0].committers[0].name; -%>
      <%= committerName %>:
        condition: service_healthy
    networks:
      - test
<% }); -%>
<% } -%>

<% }); -%>
